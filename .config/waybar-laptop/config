{
    // -------------------------------------------------------------------------
    // Global configuration
    // -------------------------------------------------------------------------
    "layer": "bottom",
    "position": "top",

    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,

    "spacing": 5, // Gaps between modules (4px)

    "modules-left": [
        "custom/wofi",
        "sway/workspaces",
        "custom/spotify"
    ],

    "modules-center": [
        "clock#date"
    ],

    "modules-right": [
        "custom/storage",
        "memory",
        "cpu",
        "wireplumber",
        "custom/screenshot_t",
        "battery",
        "tray",
        "custom/power"
    ],


    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "custom/wofi": {
        "format": "пѓ‰",
        "tooltip": false,
        "on-click-right": "",
        "on-click": "wofi --show drun --allow-images -a -i",
        "on-click-middle": "pkill -9 wofi"
    },

    "custom/screenshot_t":{
        "format":"пЂ° ",
        "on-click": "grim -g \"$(slurp)\""
    },

    "memory": {
        "interval": 30,
        "format": "п‹›  {used:0.2f} / {total:0.0f} GB",
        "on-click": "alacritty -e btop"
    },

    "custom/storage": {
        "format": "п‚  {}",
        "format-alt": "{percentage}% п‚ ",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/modules/storage.sh"
    },

    "custom/spotify": {
        "exec": "~/.config/waybar/mediaplayer.py --player spotify",
        "format": "{}  п†ј",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },

    "custom/power": {
        "format": " у°ђҐ ",
        "tooltip": false,
        "on-click": "wlogout"
    },


    "battery": {
        "interval": 2,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "п–ѓ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-icons": [
            "п‰„",
            "п‰ѓ",
            "п‰‚",
            "п‰Ѓ",
            "п‰Ђ"
        ]
    },

    "clock#date": {
        "format": "у°Ґ”  {:%H:%M \tпЃі %e %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "today-format": "<b>{}</b>"
    },

    "cpu": {
        "interval": 1,
        //"format": "п‹› {}%", // Icon: microchip
        "format": "п‹› {max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
        "max-length": 13,
        "min-length": 13
    },

    "sway/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "п„ ",
            "2": "п‰Ё",
            "3": "п„Ў",
            "4": "п†ј",
            "5": "пЃµ",
            "urgent": "пЃЄ",
            "active": "п†’",
            "default": "п„‘"
        },
        "sort-by-number": true
    },

    "wireplumber": {
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle 1>/dev/null",
        "format": "<span foreground='#fab387'>{icon}</span>  {volume}%",
        "format-muted": "пљ© ",
        "format-source": "п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ ",
            "hands-free": "п–ђ ",
            "headset": "п–ђ ",
            "phone": "п‚• ",
            "portable": "п‚• ",
            "car": "п†№ ",
            "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "]
        },
    },

    "tray": {
        "icon-size": 15,
        "spacing": 5
    }
}

{
    // -------------------------------------------------------------------------
    // Global configuration
    // -------------------------------------------------------------------------
    "layer": "bottom",
    "position": "top",

    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,

    "spacing": 5, // Gaps between modules (4px)

    "modules-left": [
        "custom/wofi",
        "sway/workspaces",
        "custom/spotify"
    ],

    "modules-center": [
        "clock#date"
    ],

    "modules-right": [
        "custom/storage",
        "memory",
//        "cpu",
        "wireplumber",
        "backlight",
        "battery",
        "tray",
        "custom/power"
    ],


    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "custom/wofi": {
        "format": "’āē",
        "tooltip": false,
        "on-click-right": "",
        "on-click": "wofi --show drun --allow-images -a -i",
        "on-click-middle": "pkill -9 wofi"
    },

    "memory": {
        "interval": 30,
        "format": "’ŗø  {used:0.2f} / {total:0.0f} GB",
        "on-click": "alacritty -e btop"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-alt": "{percent}% {icon}",
        "format-alt-click": "click-right",
        "format-icons": ["’åģ", "’äæ"],
        "on-scroll-down": "brightnessctl s 5%-",
        "on-scroll-up": "brightnessctl s +5%"
    },

    "custom/storage": {
        "format": "’éĀ {}",
        "format-alt": "{percentage}% ’éĀ",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/modules/storage.sh"
    },

    "custom/spotify": {
        "exec": "~/.config/waybar/mediaplayer.py --player spotify",
        "format": "{}  ’å╝",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },

    "custom/power": {
        "format": " ¾░Éź ",
        "tooltip": false,
        "on-click": "wlogout"
    },


    "battery": {
        "interval": 2,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "’¢ā {capacity}%",
        "format-plugged": "’ć” {capacity}%",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ]
    },

    "clock#date": {
        "format": "¾░źö  {:%H:%M \t’ü│ %e %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "today-format": "<b>{}</b>"
    },

    "cpu": {
        "interval": 1,
        //"format": "’ŗø {}%", // Icon: microchip
        "format": "’ŗø {max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
        "max-length": 13,
        "min-length": 13
    },

    "sway/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "’äĀ",
            "2": "’ē©",
            "3": "’äĪ",
            "4": "’å╝",
            "5": "’üĄ",
            "urgent": "’ü¬",
            "active": "’åÆ",
            "default": "’äæ"
        },
        "sort-by-number": true
    },

    "wireplumber": {
        "on-click": "pavucontrol",
        "on-click-right": "amixer sset Master toggle 1>/dev/null",
        "format": "<span foreground='#fab387'>{icon}</span>  {volume}%",
        "format-muted": "’Ü® ",
        "format-source": "’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’Ćź ",
            "hands-free": "’¢É ",
            "headset": "’¢É ",
            "phone": "’éĢ ",
            "portable": "’éĢ ",
            "car": "’å╣ ",
            "default": ["’Ć” ", "’Ć¦ ", "’Ć© "]
        },
    },

    "tray": {
        "icon-size": 15,
        "spacing": 5
    }
}
